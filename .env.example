# Gaslite core — copy to .env and fill in. See README.md for details.

# DeepSeek (rewrite model) — required
DEEPSEEK_API_KEY=
# Optional: defaults to https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=

# Qdrant (vector search) — required
QDRANT_API_KEY=
QDRANT_CLUSTER_URL=

# Turso / libSQL (pattern store) — required
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Mantle RPC (used by /api/verify forge fork tests)
# Optional: defaults to https://rpc.mantle.xyz
MANTLE_RPC_URL=
